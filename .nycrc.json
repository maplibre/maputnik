{
  "all": true,
  "extends": "@istanbuljs/nyc-config-typescript",
  "check-coverage": false,
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "e2e/**/*.*",
    "**/*.d.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.browser.test.tsx",
    "./coverage/**",
    "./e2e/**",
    "./dist/**",
    "node_modules"
  ],
  "report-dir": "coverage",
  "reporter": ["json", "lcov", "json-summary"]
}
